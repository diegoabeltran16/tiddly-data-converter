  "corpus_state_catalog": {
    "live_path": {
      "description": "Registro activo del canon local; puede participar en capas derivadas y chunking cuando su payload lo permite.",
      "evidence_mode": "authoritative_local",
      "outside_live_corpus": false,
      "chunk_eligibility": "eligible",
      "chunk_exclusion_reason": ""
    },
    "historical_snapshot": {
      "description": "Registro historico o reemplazado que se preserva por trazabilidad pero no debe alimentar chunking operativo.",
      "evidence_mode": "historical",
      "outside_live_corpus": true,
      "chunk_eligibility": "excluded",
      "chunk_exclusion_reason": "historical_snapshot"
    },
    "archival_only": {
      "description": "Artefacto de archivo, build, reporte generado o referencia tecnica que no debe tratarse como corpus vivo.",
      "evidence_mode": "archival",
      "outside_live_corpus": true,
      "chunk_eligibility": "excluded",
      "chunk_exclusion_reason": "archival_only"
    }
  },
  "corpus_state_resolution_rules": [
    {
      "rule_id": "archival_only_by_tag",
      "priority": 10,
      "match": {
        "tags_any": [
          "status:archival-only"
        ]
      },
      "result": {
        "corpus_state": "archival_only"
      }
    },
    {
      "rule_id": "historical_snapshot_by_superseded_tag",
      "priority": 20,
      "match": {
        "tags_prefix_any": [
          "superseded-by:"
        ]
      },
      "result": {
        "corpus_state": "historical_snapshot"
      }
    },
    {
      "rule_id": "historical_snapshot_by_state_tag",
      "priority": 30,
      "match": {
        "tags_any": [
          "state:historical-snapshot"
        ]
      },
      "result": {
        "corpus_state": "historical_snapshot"
      }
    },
    {
      "rule_id": "live_path_by_state_tag",
      "priority": 40,
      "match": {
        "tags_any": [
          "state:live-path"
        ]
      },
      "result": {
        "corpus_state": "live_path"
      }
    },
    {
      "rule_id": "archival_only_build_artifact",
      "priority": 50,
      "match": {
        "title_contains_any": [
          "/target/",
          "target/debug",
          "target/release",
          ".fingerprint",
          "__pycache__",
          ".pytest_cache",
          "coverage.csv",
          "artifacts.csv",
          "edges.csv",
          "nodes.csv",
          "relations.csv",
          "entities.json",
          "topics.json",
          "navigation_index.json",
          "source_arbitration_report.json",
          "manifest.json",
          "derivation_report.json",
          "reverse-report.json"
        ]
      },
      "result": {
        "corpus_state": "archival_only"
      }
    },
    {
      "rule_id": "archival_only_repo_path",
      "priority": 60,
      "match": {
        "repo_path_like": true,
        "tags_absent": [
          "state:live-path"
        ]
      },
      "result": {
        "corpus_state": "archival_only"
      }
    },
    {
      "rule_id": "general_fallback",
      "priority": 1000,
      "match": {},
      "result": {
        "corpus_state": "live_path"
      }
    }
  ],
  "corpus_state_transitions": [
    {
      "from": "live_path",
      "to": "historical_snapshot",
      "allowed": true
    },
    {
      "from": "live_path",
      "to": "archival_only",
      "allowed": true
    },
    {
      "from": "historical_snapshot",
      "to": "archival_only",
      "allowed": true
    },
    {
      "from": "archival_only",
      "to": "live_path",
      "allowed": false
    }
  ]
}
