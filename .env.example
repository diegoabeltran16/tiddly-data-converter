# Environment variable contract for the local agent and remote mirror flow.
# Copy to .env and adjust as needed; never commit a populated .env file.

# Primary read root for the local agent (canon and derived layers)
AGENT_PRIMARY_READ_ROOT=data/out/local/

# Durable sessions surface (staging, traceability, closure artifacts)
AGENT_SESSION_ROOT=data/out/local/sessions/

# Source for the remote mirror operation (what remote_mirror_out_local.py reads)
LOCAL_SYNC_SOURCE=data/out/local/

# The local agent never writes directly to data/out/local/tiddlers_*.jsonl.
# All canon changes go through the admission pipeline with full gate passage.
AGENT_DIRECT_CANON_WRITE=false
