{
  "registry_version": "v1",
  "schema_version": "v0",
  "registry_id": "m03-s55-corpus-governance-state-lineage-v0",
  "source_of_truth_layer": "canon",
  "description": "Machine-readable registry of governed corpus layers rooted in the local canon. Canon is the only authoritative local layer; every other layer is candidate-only, derived or non-authoritative projection.",
  "layer_classes": {
    "canon": {
      "is_canonical": true,
      "authoritative_for_local_corpus": true,
      "default_write_mode": "governed_direct_session_close",
      "promotion_into_class": false
    },
    "proposal": {
      "is_canonical": false,
      "authoritative_for_local_corpus": false,
      "default_write_mode": "manual_recovery_only",
      "promotion_into_class": "governed_merge_only"
    },
    "derived": {
      "is_canonical": false,
      "authoritative_for_local_corpus": false,
      "default_write_mode": "regenerate",
      "promotion_into_class": false
    },
    "reverse_projection": {
      "is_canonical": false,
      "authoritative_for_local_corpus": false,
      "default_write_mode": "regenerate",
      "promotion_into_class": false
    },
    "remote_projection": {
      "is_canonical": false,
      "authoritative_for_local_corpus": false,
      "default_write_mode": "exchange_only",
      "promotion_into_class": false
    }
  },
  "layers": [
    {
      "layer_id": "canon",
      "path": "data/out/local",
      "path_patterns": [
        "tiddlers_*.jsonl"
      ],
      "layer_class": "canon",
      "authority": "local_source_of_truth",
      "presence": "required",
      "lineage_parents": [],
      "validation_inputs": [],
      "allowed_uses": [
        "local_reading",
        "derivation_source",
        "reverse_source",
        "governed_merge_target"
      ],
      "must_not_replace_layers": []
    },
    {
      "layer_id": "proposals",
      "path": "data/out/local/proposals.jsonl",
      "path_patterns": [
        "proposals.jsonl"
      ],
      "layer_class": "proposal",
      "authority": "candidate_only",
      "presence": "optional",
      "lineage_parents": [],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "manual_recovery",
        "historical_candidate_storage",
        "extraordinary_governed_buffer"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "enriched",
      "path": "data/out/local/enriched",
      "path_patterns": [
        "tiddlers_enriched_*.jsonl",
        "manifest.json"
      ],
      "layer_class": "derived",
      "authority": "derived_non_authoritative",
      "presence": "required",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "inspection",
        "derived_semantics",
        "governed_export"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "ai",
      "path": "data/out/local/ai",
      "path_patterns": [
        "tiddlers_ai_*.jsonl",
        "chunks_ai_*.jsonl",
        "reports/*.json",
        "manifest.json"
      ],
      "layer_class": "derived",
      "authority": "derived_non_authoritative",
      "presence": "required",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "retrieval",
        "semantic_search",
        "rag",
        "chunk_qc"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "audit",
      "path": "data/out/local/audit",
      "path_patterns": [
        "*.json",
        "*.jsonl",
        "*.md",
        "manifest.json"
      ],
      "layer_class": "derived",
      "authority": "derived_non_authoritative",
      "presence": "required",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon",
        "enriched",
        "ai"
      ],
      "allowed_uses": [
        "compliance_audit",
        "safe_fix_planning",
        "reporting"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "reverse_html",
      "path": "data/out/local/reverse_html",
      "path_patterns": [
        "*.html",
        "*.json"
      ],
      "layer_class": "reverse_projection",
      "authority": "reverse_projection_only",
      "presence": "required",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "round_trip_verification",
        "human_reading",
        "tiddlywiki_import"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "export",
      "path": "data/out/local/export",
      "path_patterns": [
        "*.json",
        "*.jsonl"
      ],
      "layer_class": "derived",
      "authority": "transient_export_only",
      "presence": "optional",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "temporary_export",
        "regen_inputs",
        "verification"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    },
    {
      "layer_id": "microsoft_copilot",
      "path": "data/out/local/microsoft_copilot",
      "path_patterns": [
        "manifest.json",
        "navigation_index.json",
        "entities.json",
        "topics.json",
        "source_arbitration_report.json",
        "nodes.csv",
        "edges.csv",
        "artifacts.csv",
        "coverage.csv",
        "overview.txt",
        "reading_guide.txt",
        "bundles/*.txt",
        "spec/summaries/*.md",
        "spec/summaries/*.json",
        "spec/plan_de_implementacion_s61.md",
        "spec/checklist_global_s61.md",
        "spec/memoria_decisiones_s61.md"
      ],
      "layer_class": "derived",
      "authority": "derived_non_authoritative_agent_projection",
      "presence": "required",
      "lineage_parents": [
        "canon",
        "enriched",
        "ai",
        "audit",
        "export"
      ],
      "validation_inputs": [
        "canon",
        "enriched",
        "ai",
        "audit",
        "export"
      ],
      "allowed_uses": [
        "agent_reading",
        "remote_navigation",
        "governed_context_projection",
        "copilot_surface"
      ],
      "must_not_replace_layers": [
        "canon",
        "enriched"
      ]
    },
    {
      "layer_id": "remote",
      "path": "data/out/remote",
      "path_patterns": [
        "*"
      ],
      "layer_class": "remote_projection",
      "authority": "remote_exchange_only",
      "presence": "optional",
      "lineage_parents": [
        "canon"
      ],
      "validation_inputs": [
        "canon"
      ],
      "allowed_uses": [
        "projection",
        "exchange",
        "remote_preparation"
      ],
      "must_not_replace_layers": [
        "canon"
      ]
    }
  ],
  "lineage_edges": [
    {
      "from": "canon",
      "to": "enriched",
      "mode": "deterministic_projection",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "ai",
      "mode": "governed_projection_and_chunking",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "audit",
      "mode": "audit_projection",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "reverse_html",
      "mode": "reverse_projection",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "export",
      "mode": "transient_export_projection",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "microsoft_copilot",
      "mode": "multi_source_projection_input",
      "authority_transfer": "none"
    },
    {
      "from": "enriched",
      "to": "microsoft_copilot",
      "mode": "multi_source_projection_input",
      "authority_transfer": "none"
    },
    {
      "from": "ai",
      "to": "microsoft_copilot",
      "mode": "multi_source_projection_input",
      "authority_transfer": "none"
    },
    {
      "from": "audit",
      "to": "microsoft_copilot",
      "mode": "multi_source_projection_input",
      "authority_transfer": "none"
    },
    {
      "from": "export",
      "to": "microsoft_copilot",
      "mode": "multi_source_projection_input",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "remote",
      "mode": "remote_projection",
      "authority_transfer": "none"
    },
    {
      "from": "canon",
      "to": "proposals",
      "mode": "validation_context_only",
      "authority_transfer": "none"
    },
    {
      "from": "proposals",
      "to": "canon",
      "mode": "governed_merge_only",
      "authority_transfer": "conditional",
      "requirements": [
        "explicit_governed_merge_session_or_user_instruction",
        "canon_preflight_strict",
        "collision_free_canonical_candidate"
      ]
    }
  ],
  "assertions": [
    {
      "assertion_id": "canon-local-source-of-truth",
      "rule": "canon is the only authoritative local corpus layer"
    },
    {
      "assertion_id": "proposals-not-canon",
      "rule": "proposals are canonized candidates and never equal canon by default"
    },
    {
      "assertion_id": "reverse-html-not-canon",
      "rule": "reverse_html is a projection output and cannot replace canon authority"
    },
    {
      "assertion_id": "remote-not-authoritative",
      "rule": "remote output is exchange-only and has no local authority"
    },
    {
      "assertion_id": "microsoft-copilot-not-authoritative",
      "rule": "microsoft_copilot is an agent-readable derived projection and cannot replace canon or enriched authority"
    },
    {
      "assertion_id": "derived-layers-subordinate",
      "rule": "enriched, ai, audit, export and microsoft_copilot remain subordinate to canon"
    }
  ]
}
