{
  "canon_artifact_role": "canon_export",
  "schema_version": "v0",
  "runtime_data_roots": [
    "data/in",
    "data/out",
    "data/reverse_html"
  ],
  "local_output_root": "data/out/local",
  "remote_output_root": "data/out/remote",
  "session_proposal_artifact_pattern": "data/out/local/proposals.jsonl",
  "reverse_html_root": "data/reverse_html",
  "direct_canon_write_default": "forbidden_unless_explicit_governed_session",
  "source_of_truth": "ordered shard set `tiddlers_1.jsonl` .. `tiddlers_7.jsonl`",
  "source_of_truth_description": "The ordered shard set is the unique, authoritative, auditable, reversible, deterministic source of truth for the tiddler corpus. A monolithic JSONL view may exist temporarily, but it is derived and non-authoritative.",
  "required_fields": [
    "schema_version",
    "key",
    "title"
  ],
  "identity_fields": [
    "id",
    "canonical_slug",
    "version_id"
  ],
  "reading_mode_fields": [
    "content_type",
    "modality",
    "encoding",
    "is_binary",
    "is_reference_only"
  ],
  "semantic_fields": [
    "role_primary",
    "roles_secondary",
    "tags",
    "taxonomy_path",
    "semantic_text",
    "content",
    "normalized_tags",
    "raw_payload_ref",
    "asset_id",
    "mime_type"
  ],
  "derived_projection_fields": [
    "content",
    "normalized_tags"
  ],
  "context_relation_fields": [
    "document_id",
    "section_path",
    "order_in_document",
    "relations"
  ],
  "editable_fields": [
    "key",
    "title",
    "text",
    "created",
    "modified",
    "source_type",
    "source_position",
    "source_tags",
    "source_fields",
    "source_role"
  ],
  "derived_fields": [
    "id",
    "canonical_slug",
    "version_id",
    "content_type",
    "modality",
    "encoding",
    "is_binary",
    "is_reference_only",
    "role_primary",
    "roles_secondary",
    "tags",
    "taxonomy_path",
    "semantic_text",
    "content",
    "normalized_tags",
    "raw_payload_ref",
    "asset_id",
    "mime_type",
    "document_id",
    "section_path",
    "order_in_document",
    "relations"
  ],
  "reverse_required_fields": [
    "schema_version",
    "key",
    "title"
  ],
  "reverse_authoritative_fields": [
    "title",
    "text",
    "created",
    "modified",
    "source_type",
    "source_tags",
    "source_fields"
  ],
  "reverse_optional_fields": [],
  "reverse_excluded_fields": [
    "id",
    "canonical_slug",
    "version_id",
    "content_type",
    "modality",
    "encoding",
    "is_binary",
    "is_reference_only",
    "role_primary",
    "roles_secondary",
    "taxonomy_path",
    "semantic_text",
    "content",
    "normalized_tags",
    "raw_payload_ref",
    "asset_id",
    "mime_type",
    "document_id",
    "section_path",
    "order_in_document",
    "relations",
    "source_role"
  ],
  "allowed_top_level_fields": [
    "schema_version",
    "id",
    "key",
    "title",
    "canonical_slug",
    "version_id",
    "content_type",
    "modality",
    "encoding",
    "is_binary",
    "is_reference_only",
    "role_primary",
    "roles_secondary",
    "tags",
    "taxonomy_path",
    "semantic_text",
    "content",
    "normalized_tags",
    "raw_payload_ref",
    "asset_id",
    "mime_type",
    "document_id",
    "section_path",
    "order_in_document",
    "relations",
    "source_tags",
    "source_fields",
    "source_type",
    "source_position",
    "source_role",
    "text",
    "created",
    "modified"
  ],
  "validation_modes": {
    "strict": {
      "description": "Validates shape and invariants without modifying anything. Fails on any inconsistency.",
      "corrects_derived": false,
      "rejects_unknown_fields": true,
      "rejects_inconsistent_derived": true
    },
    "normalize": {
      "description": "Recalculates derived fields, suppresses trivial differences, emits normalized JSONL and a report.",
      "corrects_derived": true,
      "rejects_unknown_fields": true,
      "rejects_inconsistent_derived": false
    },
    "reverse-preflight": {
      "description": "Validates that the canon has all fields necessary for reverse to TiddlyWiki. Accepts a single JSONL file or an ordered shard directory. Does not write HTML.",
      "corrects_derived": false,
      "rejects_unknown_fields": false,
      "rejects_inconsistent_derived": false
    }
  },
  "rejection_rules": [
    {
      "rule_id": "missing-required-field",
      "description": "Every canon line must have all required_fields non-empty.",
      "severity": "error"
    },
    {
      "rule_id": "unknown-top-level-field",
      "description": "Top-level fields not in allowed_top_level_fields are rejected.",
      "severity": "error"
    },
    {
      "rule_id": "inconsistent-derived-id",
      "description": "If id is present, it must match recomputed UUIDv5 from key.",
      "severity": "error"
    },
    {
      "rule_id": "inconsistent-derived-slug",
      "description": "If canonical_slug is present, it must match recomputed slug from title.",
      "severity": "error"
    },
    {
      "rule_id": "inconsistent-derived-version-id",
      "description": "If version_id is present, it must match recomputed sha256 from normative shape.",
      "severity": "error"
    },
    {
      "rule_id": "semantic-text-redundant",
      "description": "semantic_text that equals text must be null per S38 policy.",
      "severity": "warning"
    },
    {
      "rule_id": "inconsistent-derived-content-plain",
      "description": "If content.plain is present, it must match deterministic recomputation from authoritative content.",
      "severity": "error"
    },
    {
      "rule_id": "inconsistent-derived-normalized-tags",
      "description": "If normalized_tags is present, it must match deterministic recomputation from the authoritative tag projection.",
      "severity": "error"
    },
    {
      "rule_id": "wrong-schema-version",
      "description": "schema_version must be v0.",
      "severity": "error"
    }
  ],
  "canon_source_preflight": {
    "accepts": [
      "single_jsonl_file",
      "ordered_shard_directory"
    ],
    "ordered_shard_pattern": "tiddlers_<n>.jsonl",
    "rejects_duplicate_shard_content": true,
    "rejects_duplicate_exact_lines": true,
    "rejects_duplicate_titles": true,
    "rejects_duplicate_keys": true
  },
  "derived_layers_registry_ref": "contratos/projections/derived_layers_registry.json",
  "invariants": [
    "The ordered shard set is the unique source of truth.",
    "One tiddler per line.",
    "text is the reversible source; semantic_text never substitutes text.",
    "content.plain and normalized_tags are derived helper fields and never substitute their source fields.",
    "The reverse contract may read from a shard directory or a single canonical JSONL file, but shard directories remain the primary operational mode.",
    "Decisions from S34–S43 are not degraded.",
    "A change cannot be accepted without validation.",
    "An inconsistent derived field is never accepted silently.",
    "Every failure must produce an explicit reason.",
    "The normalizer must be deterministic."
  ]
}
